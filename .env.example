PORT=8080
APP_BASE_URL=http://localhost:8080
TIMEZONE=America/Detroit
SLOT_DURATION_MINUTES=60
SLOT_BUFFER_MINUTES=10
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=change-me-too

# Replace these with the calendar IDs for each trainer.
# If everything runs through one BigDawgz calendar, use the same ID for both.
CALENDAR_ID_JHAREL=primary
CALENDAR_ID_NATE_COLLINS=primary

# Google service account credentials
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"

# Optional automatic booking notifications
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email-login
SMTP_PASS=your-email-password
SMTP_FROM="BigDawgz Performance <bookings@bigdawgzperformance.com>"

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+15555555555

# Optional waiver link shown on the confirmation page and in booking emails
WAIVER_URL=https://your-waiver-link-here

# Business contact info used in booking notifications
BUSINESS_PHONE=305-812-6181
BUSINESS_EMAIL=BigDawgzTraining@gmail.com
